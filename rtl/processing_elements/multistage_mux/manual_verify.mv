"
    localparam int_t [SMALL - 1 : 0][SOLAR - 1 : 0] MUX_TREE_MAP         = multistage_mux_MUX_TREE_MAP(STAGES, GROUP_SIZE, SIZE),

"
- defined as
"
    function automatic int_t [SMALL - 1 : 0][SOLAR - 1 : 0] multistage_mux_MUX_TREE_MAP(int STAGES, int GROUP_SIZE, int SIZE);
        int_t [SMALL - 1 : 0][SOLAR - 1 : 0] mux_tree_map;
        int counter;
        
        // initialize all values to 0
        for(int r = 0; r < SMALL; r++) begin
            for(int c = 0; c < SOLAR; c++) begin
                mux_tree_map[r][c] = 0;
            end
        end

        // set 0th row to 1s for each input 
        for(int i = 0; i < SIZE; i++) begin
            mux_tree_map[0][i] = 1;
        end

        // *we set the lowest index for each group the number of actual inputs available
        // and is used to deal with partial groups

        for(int group = 0; group < SIZE; group += GROUP_SIZE) begin
            counter = 0;
            for(int g = 0; g < GROUP_SIZE; g++) begin
                if(mux_tree_map[0][group + g] != 0) counter++;
            end
            mux_tree_map[0][group] = counter;
        end


        // mux tree, repeat the two steps above for each proceeding stage
        for(int row = 1; row <= STAGES; row++) begin
            for(int col = 0; col < SIZE; col++) begin
                if(((col * GROUP_SIZE) + 0) >= SIZE) break;

                // check if there are inputs from previous row to mux, 
                // set as 1 in current row if there is
                if(mux_tree_map[row - 1][((col * GROUP_SIZE) + 0)] != 0) begin
                    mux_tree_map[row][col] = 1;
                end
            end

            // set group completness in the current row, in the lowest index *
            for(int group = 0; group < SIZE; group += GROUP_SIZE) begin
                counter = 0;
                for(int g = 0; g < GROUP_SIZE; g++) begin
                    if(mux_tree_map[row][group + g] != 0) counter++;
                end
                mux_tree_map[row][group] = counter;
            end
        end

        return mux_tree_map;
    endfunction
"
- correct arguments passed in
- correct return type of function
- 'int_t [SMALL - 1 : 0][SOLAR - 1 : 0] mux_tree_map;
    - SMALL is 16, we don't expect more stage reductions, i.e at 2:1 mux (which is the minimum),
      that would be 2^16 inputs, actually 2^8 is more appropriate but we want to oversize not
      perfectly size
    - SOLAR is 512, meaning we are capping at a 9 bit selector size
- we intialize all values to 0
- set inputs to 1 for first row
- count and set for each group its fullness and put in the lowest index in the group
    - this accounts for partially filled groups
    - this is the general pattern moving forward for the rest of the rows
    - 'group' increments by GROUP_SIZE
    - 'g' increments for each element in the group
    - index via 'group + g'
    - see this logic applied to the rest of the rows
        - we set to 1 in our current row and col if 'mux_tree_map[row - 1][((col * GROUP_SIZE) + 0)] != 0'
        - and 'if(((col * GROUP_SIZE) + 0) >= SIZE) break' to prevent out of bounds indexing
        - then count th enumber of actual inputs and set the value in the group index
- then we return mux_tree_map
[Marc103 + Codex 5.5 - 07/03/26]

"
    localparam                                      LATENCY              = multistage_mux_LATENCY(REGISTERED_IN, STAGES)
"
- defined as
"
    function automatic int multistage_mux_LATENCY(int REGISTERED_IN, int STAGES);
        int latency = 0;
        if(REGISTERED_IN == 1) latency++;
        latency = latency + STAGES - 1;
        return latency;
    endfunction
"
- correct arguments passed in correctly
- REGISTERED_IN adds a cycle
- then STAGES - 1 additional cycles
    - actually from how STAGES is calculated, it should always be >= 1 
