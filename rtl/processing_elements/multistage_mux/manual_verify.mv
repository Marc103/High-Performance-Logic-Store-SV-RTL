"
    logic [SIZE - 1 : 0][DATA_WIDTH - 1 : 0] data;
    logic [SIZE - 1 : 0][DATA_WIDTH - 1 : 0] data_g;

    logic [SELECTOR_WIDTH - 1 : 0] sel;
    logic [SELECTOR_WIDTH - 1 : 0] sel_g;

    always@(posedge clk_i) begin
        data <= data_i;
        sel  <= sel_i;
    end

    assign data_g = (REGISTERED_IN == 1) ? data : data_i;
    assign sel_g  = (REGISTERED_IN == 1) ? sel : sel_i;
"
- standard REGISTERED_IN procedure
[Marc103 + Codex 5.5 - 07/03/26]

"
    // seperating it like this allows us to refer directly a combinational result
    // instead of just registered result
    logic [STAGES : 0][SIZE - 1 : 0][DATA_WIDTH - 1 : 0] mux_data;
    logic [STAGES - 1 : 0][SIZE - 1 : 0][DATA_WIDTH - 1 : 0] mux_data_pipeline;
    
    logic [STAGES - 1 : 0][SELECTOR_WIDTH - 1 : 0] sel_pipeline;

"
- correct type declarations
    - 'STAGES : 0' is intentional instead of 'STAGES - 1' for mux_data but we never
       use [STAGES] for the mux_data_pipeline and sel_pipeline, hence they are 
       STAGES - 1 instead.
[Marc103 + Codex 5.5 - 07/03/26]

"
    always_comb begin
        mux_data[0]          = 'x;
        mux_data_pipeline[0] = data_g;
        sel_pipeline[0]      = sel_g;

        for(int row = 1; row <= STAGES; row++) begin
            for(int col = 0; col < SIZE; col++) begin
                if(MUX_TREE_MAP[row][col] != 0) begin
                    logic [GROUP_SIZE - 1 : 0][DATA_WIDTH - 1 : 0]           group_mux_data;
                    logic                     [GROUP_SELECTOR_WIDTH - 1 : 0] sel;

                    // wire inputs, bits are set to 'x to fill partial groups
                    group_mux_data = 'x;
                    for(int g = 0; g < MUX_TREE_MAP[row - 1][col * GROUP_SIZE]; g++) begin
                        group_mux_data[g] = mux_data_pipeline[row - 1][(col * GROUP_SIZE) + g];
                    end

                    // wire selector, bits are set to 0 to fill partial sel
                    sel = '0;
                    for (int s = 0; s < GROUP_SELECTOR_WIDTH; s++) begin
                        if (((row - 1) * GROUP_SELECTOR_WIDTH + s) < SELECTOR_WIDTH) begin
                            sel[s] = sel_pipeline[row-1][(row - 1) * GROUP_SELECTOR_WIDTH + s];
                        end
                    end

                    // perform actual mux
                    mux_data[row][col] = group_mux_data[sel];
                end
            end
        end 
    end

    always@(posedge clk_i) begin
        for(int row = 1; row < STAGES; row++) begin
            mux_data_pipeline[row] <= mux_data[row];
            sel_pipeline[row] <= sel_pipeline[row - 1]; 
        end 
    end

    assign data_o = mux_data[STAGES][0];
"
- we set the starting values of mux_data, mux_data_pipeline and sel_pipeline
- 'mux_data[row]' represents the combinatorial output of the previous row
- 'mux_data_pipeline[row]' stores the combinatorial output in registers (clocked)
- as I wrote in the RTL comments
    Flow is:

        mux_data_pipeline[row-1]..  -----|
                                         |
                                         |
                                         V
        mux_data_pipeline[row]... <----- mux_data[row]...    
        |                                |
        |                                |
        V                                V
        represents                  represents
        registered                  combinational
        output at that              output at that
        stage                       stage
- [0] row represents the input from the *_g values, and thus mux_data[0] is set to 'x
- the for loop row goes from 1 -> STAGES (inclusive)
- the inner for loop col goes from 1 -> SIZE (exclusive)
- nothing happens if MUX_TREE_MAP[row][col] is 0, as according to how we the map is created, it means
  no inputs from the previous row index into here
- otherwise, we first declare two local variables, 'group_mux_data' and 'sel', which represent the
  elements we are going to mux and their respective sel line. The only real reason we need these local\
  variables is to deal with impartial groups and selector lines.
- for the group_mux_data, we default to 'x then fill the repsective elements with the previous
  row values
    - g going from 0 -> MUX_TREE_MAP[row - 1][col * GROUP_SIZE] is correct, as this is where
      the group completness number is found for that group
    - indexing [row - 1][(col * GROUP_SIZE) + g] is correct, in particular, using mux_data_pipeline
- for the sel, we default to '0, then fill the repsective sel bits with the correct 
    - s going from 0 to GROUP_SELECTOR_WIDTH (exclusive) is correct but
    - we need an additional check for out of bounds indexing,
        - (row - 1) * GROUP_SELECTOR_WIDTH + s is correct index to look at, thus we check
          it against the overall SELECTOR_WIDTH, and set the bit value if it is within bound 
          (using the same index)
        - we refer to to the appropriate sel_pipeline index [row - 1][(row - 1) * GROUP_SELECTOR_WIDTH + s]
- finally we peform the actual mux and assign it correspondlingly 'mux_data[row][col] = group_mux_data[sel];'
- in the sequential always block, we pipelien the mux data and sel value
    - row goes from 1 to STAGES (exclusive)
    - as discussed before with how mux_data[row] is calculated using mux_data_pipeline[row - 1][..],
      it is correct that 'mux_data_pipeline[row] <= mux_data[row];'
    - 'sel_pipeline[row] <= sel_pipeline[row - 1];' is correct
- finally, we assign 'data_o = mux_data[STAGES][0]', the combinatorial output of mux_data_pipeline[STAGES - 1][..]
