"
    input clk_i,

    input [SIZE - 1 : 0][DATA_WIDTH - 1 : 0]     data_i,
    input               [SELECTOR_WIDTH - 1 : 0] sel_i,

    output              [DATA_WIDTH - 1 : 0] data_o
"
- types and no missing signals
