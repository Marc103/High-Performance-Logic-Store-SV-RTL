    localparam int_t [SMALL - 1 : 0][SOLAR - 1: 0] ENCODE_MAX_TREE_MAP        = priority_encoder_ENCODE_MAX_TREE_MAP(ENCODE_GROUPS, ENCODE_DEPTH),
"
- correct return types, arguments
- defined as 
"
    function automatic int_t [SMALL - 1 : 0][SOLAR - 1 : 0] priority_encoder_ENCODE_MAX_TREE_MAP(int ENCODE_GROUPS, int ENCODE_DEPTH);
        int_t [SMALL - 1 : 0][SOLAR - 1 : 0] max_tree_map;

        // initialize all values to 0
        for(int r = 0; r < SMALL; r++) begin
            for(int c = 0; c < SOLAR; c++) begin
                max_tree_map[r][c] = 0;
            end
        end
        
        // set 0th row to 1s for each group
        for(int group = 0; group < ENCODE_GROUPS; group++) begin
            max_tree_map[0][group] = 1;
        end

        // determine tree for rest of rows ( <= ENCODE_DEPTH is intentional)
        for(int row = 1; row <= ENCODE_DEPTH; row++) begin
            for(int col = 0; col < ENCODE_GROUPS; col++) begin
                if(((col * 2) + 0) >= ENCODE_GROUPS) break;
                if(max_tree_map[row - 1][(col * 2) + 0] | max_tree_map[row - 1][(col * 2) + 1]) begin
                    max_tree_map[row][col] = 1;
                end
            end
        end

        return  max_tree_map;
    endfunction
"
- declaration type is correct of max_tree_map
- initializing to all 0, r and c conditions correct.
- then the 0th row (first layer) is set to 1 for each encode group
- then, each row goes from 1 to ENCODE_DEPTH (inclusive), correct
- each col goes from 0 to ENCODE_GROUPS (exclusive)
    - this is oversized, since at each layer the number should decrease by 2, but
      it keeps the code clean due to issues with odd sized layers
- each element in the current row is made from the pair of the previous row
    - we guard with a break, making sure '(col * 2) + 0' is within bounds
        - we don't check '(col * 2) + 1', the actual array is much larger and cases
          where the ENCODE_GROUPS are odd still needs to considered regardless
    - we check for 1 on either size (although the only two cases are 1,1 or 1,0), 
      that signifies we have a result in the current element
    - '[row - 1][(col * 2) + 0]' and '[row - 1][(col * 2) + 1]' are correct
    - final [row][col] for assignment is correct 
[Marc103 + Codex 5.5 - 06/18/26]

"
    localparam                                     ENCODE_FIRST_LAYER_LATENCY = max_LATENCY                         (1, GRADE),
    localparam                                     ENCODE_REST_LAYERS_LATENCY = max_LATENCY                         (0, GRADE),
"
- check correct arguments passed into max_LATENCY, which should be REGISTERED_IN and GRADE
    - first one, REGISTERED_IN is 1, correct
    - rest layers, REGISTERED_IN is 0, correct
- otherwise, max_LATENCY() has been verified in the max folder
[Marc103 + Codex 5.5 - 06/18/26]

"
    localparam                                     LATENCY                    = priority_encoder_LATENCY            (REGISTERED_IN, ENCODE_DEPTH, ENCODE_FIRST_LAYER_LATENCY, ENCODE_REST_LAYERS_LATENCY),
"
- correct arguments passed in
- defined as
"
    function automatic int priority_encoder_LATENCY(int REGISTERED_IN, int ENCODE_DEPTH, int ENCODE_FIRST_LAYER_LATENCY, int ENCODE_REST_LAYERS_LATENCY);
        int latency = 0;
        if(REGISTERED_IN == 1) latency++;
        if(ENCODE_DEPTH >= 1) latency += ENCODE_FIRST_LAYER_LATENCY;
        if(ENCODE_DEPTH >= 2) latency += (ENCODE_REST_LAYERS_LATENCY * (ENCODE_DEPTH - 1));
        return latency;
    endfunction
"
- latency starts as 0
- REGISTERED_IN adds 1 cycle
- ENCODE_DEPTH >= 1 checks if there is at least 1 layer for the tree (if there is a tree), in which
  case we add the ENCODE_FIRST_LAYER_LATENCY to it
- ENCODE_DEPTH >= 2 checks if there are more layers afterwards, to which we add the ENCODE_REST_LAYERS_LATENCY
  for each additional layer after the first, hence ENCODE_REST_LAYERS_LATENCY * (ENCODE_DEPTH - 1)

"
