    logic [ENCODE_GROUPS - 1 : 0][OUTPUT_DATA_WIDTH - 1 : 0] encoded;
    
    // encode values layer
    always_comb begin
        for(int group = 0; group < ENCODE_GROUPS; group++) begin
            encoded[group] = 0;
            for(int i = (group * LUTX); i < ((group + 1) * LUTX); i++) begin
                if(i < INPUT_DATA_WIDTH) begin // if within bounds check since last group may not be full
                    if(priority_xkeyword_g[i]) begin
                        encoded[group] = i;
                    end
                end
            end
        end
    end

"
- packed types are correct, we ENCODE_GROUPS number of OUTPUT_DATA_WIDTHs
- basic logic is, each group of signals gets encoded to their respective value
    - group goes from 0 -> ENCODE_GROUPS (exclusive)
    - as a default start, we set the encoded[group] to 0
    - initial i = (group * LUTX) is correct. then we proceed i++ until < the next group, hence (group + 1) * LUTX
    - then the if statement encodes the value with a priority, this is because i goes from LSB to MSB, so the MSB set
      bit gets priority, as we expect.
    - where i represent the value that a set bit would be, it is guaranteed that i would fit in OUTPUT_DATA_WIDTH
    - we also know, since the for loop consists of LUTX iterations, that this logic should map perfectly into the 
      LUTX, instead of creating chain logic
