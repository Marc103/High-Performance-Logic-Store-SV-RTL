    // Queue BRAM instantiations.
    generate
        for(genvar i = 0; i < NUMBER_OF_QUEUES; i++) begin
            if(READ_THEN_WRITE == 1) begin
                bram_dual_port_simple #(
                    .ADDR_WIDTH(ADDR_WIDTH),
                    .DATA_WIDTH(DATA_WIDTH),
                    .REGISTERED_IN(REGISTERED_IN_BRAM)
                ) queue_memory (
                    // write port
                    .clk_0_i  (clk_i),
            
                    .en_0_i   (en_0_delay),
                    .wr_en_i  (wr_en_delay),
                    .wr_addr_i(wr_addr_delay),
                    .wr_data_i(wr_data_delay[i]),

                    // read port
                    .clk_1_i(clk_i),

                    .en_1_i   (en_1),
                    .rd_addr_i(rd_addr),
                    .rd_data_o(rd_data[i])
                );
            end else begin
                bram_dual_port_simple #(
                    .ADDR_WIDTH(ADDR_WIDTH),
                    .DATA_WIDTH(DATA_WIDTH),
                    .REGISTERED_IN(REGISTERED_IN_BRAM)
                ) queue_memory (
                    // write port
                    .clk_0_i  (clk_i),
            
                    .en_0_i   (en_0),
                    .wr_en_i  (wr_en),
                    .wr_addr_i(wr_addr),
                    .wr_data_i(wr_data),

                    // read port
                    .clk_1_i(clk_i),

                    .en_1_i   (en_1),
                    .rd_addr_i(rd_addr),
                    .rd_data_o(rd_data[i])
                );
            end
        end
    endgenerate
