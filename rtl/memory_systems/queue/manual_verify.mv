"
    // read/write port setting for REGISTERED_IN
    logic                                                push;
    logic [NUMBER_OF_QUEUES - 1 : 0][DATA_WIDTH - 1 : 0] wr_data;
    logic                                                pop;
    logic                                                full;
    logic                                                empty;

    always@(posedge clk_i) begin
        push     <= push_i;
        wr_data  <= wr_data_i;
        pop      <= pop_i;
        full     <= full_o;
        empty    <= empty_o;
    end
"
